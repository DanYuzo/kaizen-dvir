  "scripts": {
    "lint": "node -e \"process.exit(0)\"",
    "typecheck": "node -e \"process.exit(0)\"",
    "test": "node tests/run.js",
    "build:manifest": "node bin/build-canonical-manifest.js"
  },
  "dependencies": {},
  "devDependencies": {}
