{
  "name": "@DanYuzo/kaizen-dvir",
  "version": "1.5.0-rc.0",
  "description": "KaiZen — macro framework that orchestrates células (v1.5 / M6 Distribution & Update)",
  "license": "MIT",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanYuzo/kaizen-dvir.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "bin": {
