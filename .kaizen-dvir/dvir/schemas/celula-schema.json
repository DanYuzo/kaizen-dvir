{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kaizen.synkra/celula-schema.json",
  "title": "KaiZen Celula Manifest (expanded v1.4)",
  "description": "Strict schema for celula.yaml. Grounded in docs/kaizen/prd-v1/04-architecture.md (cell manifest section) and Epic KZ-M2 § Story M2.5. Draft-07, strict types, no additionalProperties at root. M4.1 extends the schema with FR-120 optional fields (name, version, slashPrefix, kaizen block, critical_invariants) — forward-compatible additive extension, does not change M1/M2/M3 contract. M4.2 deferred-fix follow-up adds optional `components.internal_helpers` to declare shared utility modules (e.g. `ost-writer.js`) without polluting `components.agents` (which stays reserved for personas with frontmatter, phases, and authority).",
  "type": "object",
  "additionalProperties": false,
  "required": ["description", "boot", "tiers", "commands", "components"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "slashPrefix": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "kaizen": {
      "type": "object",
      "properties": {
        "minVersion": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 }
      }
    },
    "boot": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tiers": {
      "type": "object",
      "minProperties": 1
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "triggers": { "type": "string", "minLength": 1 },
          "agent": { "type": "string", "minLength": 1 }
        }
      }
    },
    "components": {
      "type": "object",
      "required": ["templates", "checklists", "kbs"],
      "properties": {
        "agents": { "type": "array", "items": { "type": "string" } },
        "tasks": { "type": "array", "items": { "type": "string" } },
        "workflows": { "type": "array", "items": { "type": "string" } },
        "templates": { "type": "array", "items": { "type": "string" } },
        "checklists": { "type": "array", "items": { "type": "string" } },
        "kbs": { "type": "array", "items": { "type": "string" } },
        "internal_helpers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "path", "type", "purpose"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "type": {
                "type": "string",
                "enum": ["shared_utility", "internal_module"]
              },
              "purpose": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "authorities": {
      "type": "object",
      "properties": {
        "exclusive": { "type": "array", "items": { "type": "string" } }
      }
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "celulas": { "type": "array", "items": { "type": "string" } }
      }
    },
    "critical_invariants": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
