{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kaizen.synkra/task-contract-schema.json",
  "title": "KaiZen Task Contract (Yotzer F9)",
  "description": "Strict schema for per-Task YAML contracts emitted by contract-builder at F9 (M4.4). Validated DIRECTLY by M3.4 Schema Gate without YAML→JSON intermediate conversion (FR-020, D-v1.1-06). Per-field pt-BR error on violation (AC-104).",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "description", "inputs", "outputs", "gates"],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "description"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "description"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "gates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "schema_reference": {
      "type": "string",
      "minLength": 1
    }
  }
}
