# KaiZen runtime directory — ephemeral, never committed (CON-004)
# Criado pelo `kaizen init` no workspace do usuário; logs/handoffs lá são
# histórico LOCAL da instância de uso, não do framework. Não distribuir.
.kaizen/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS artifacts
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# Build / distribution
*.tarball
*.log
dist/

# Tests — não distribuídos via tarball (CON-100)
tests/
