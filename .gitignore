# KaiZen runtime directory — ephemeral, never committed (CON-004)
# Criado pelo `kaizen init` no workspace do usuário; logs/handoffs lá são
# histórico LOCAL da instância de uso, não do framework. Não distribuir.
.kaizen/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS artifacts
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# Build / distribution
*.tarball
*.log
dist/

# Tests — pre-existing convention: most test trees are local-only;
# distribution exclusion is enforced by package.json `files` whitelist
# (CON-008), so this .gitignore rule covers reproducibility convention,
# not tarball exclusion.
tests/m1/
tests/m1.1/
tests/m1.2/
tests/m1.3/
tests/m2/
tests/m3/
tests/m4/
tests/run.js
# Exception (M6.1): the M6 acceptance test suite IS tracked in git.
# Story M6.1 declares `tests/m6/expected-package-contents.txt` as a
# committed baseline (AC8 / KZ-M6-R5 mitigation) and four M6 acceptance
# tests (`tests/m6/test-*.js`) verify the published package shape. These
# must be reproducible across maintainers — they are NOT in the npm
# tarball because the package.json `files` whitelist excludes `tests/`.
